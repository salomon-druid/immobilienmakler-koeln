---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Kontakt">
  <Header activePage="kontakt" />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <section class="mb-16">
      <h1 class="text-3xl font-bold text-gray-900 mb-6">
        Kontaktieren Sie uns
      </p>
      <p class="text-lg text-gray-600 mb-8">
        Wir freuen uns auf Ihre Anfrage. Ob Sie eine Immobilie bewerten lassen möchten, Fragen zum Verkauf haben oder eine Beratung benötigen - wir sind für Sie da.
      </p>
    </section>
    
    <div class="grid gap-8 sm:grid-cols-2">
      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          Nachricht senden
        </p>
        <form class="space-y-6" 
              on:submit={(e) => {
                e.preventDefault();
                alert('Nachricht gesendet! Wir werden uns bald bei Ihnen melden.');
                e.target.reset();
              }}>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                Name <span class="text-red-500">*</span>
              </label>
              <input type="text" id="name" name="name" required
                     class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                     placeholder="Max Mustermann" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                E-Mail <span class="text-red-500">*</span>
              </label>
              <input type="email" id="email" name="email" required
                     class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                     placeholder="max@example.com" />
            </div>
          </div>
          
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
              Telefonnummer
            </label>
            <input type="tel" id="phone" name="phone"
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                   placeholder="+49 123 456789" />
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">
              Betreff
            </label>
            <input type="text" id="subject" name="subject"
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                   placeholder="Immobilienbewertung anfragen" />
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
              Nachricht <span class="text-red-500">*</span>
            </label>
            <textarea id="message" name="message" rows="5" required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                      placeholder="Wie können wir Ihnen helfen?"></textarea>
          </div>
          
          <div class="flex items-start">
            <div class="flex items-center h-4">
              <input id="privacy" type="checkbox" name="privacy" required
                     class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
            </div>
            <label for="privacy" class="ml-2 block text-sm text-gray-900">
              Ich habe die <a href="#" class="text-indigo-600 hover:underline">Datenschutzerklärung</a> gelesen und stimme ihr zu.
            </label>
          </div>
          
          <button type="submit"
                  class="w-full btn-primary mt-4 px-6 py-3 text-lg font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus-ring-indigo-500 focus:ring-offset-2">
            Nachricht senden
          </button>
        </form>
      </div>
      
      <!-- Contact Info -->
      <div class="space-y-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          Unser Büro
        </p>
        <div class="space-y-4 text-gray-600">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2-1.343-2-3-2zm0-6c1.105 0 2 .895 2 2s-.895 2-2 2-2-.895-2-2 .895-2 2-2zm0 10c-4.411 0-8 3.589-8 8s3.589 8 8 8 8-3.589 8-8-3.589-8-8-8z"/></svg>
            </div>
            <div class="ml-3">
              <div class="font-medium">Immobilienmakler Köln</div>
              <div>Musterstraße 123</div>
              <div>50667 Köln</div>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v10l-5-2.5L5 15V5z"/></svg>
            </div>
            <div class="ml-3">
              <div class="font-medium">Telefon</div>
              <div><a href="tel:+492211234567" class="text-indigo-600 hover:underline">+49 221 1234567</a></div>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div class="ml-3">
              <div class="font-medium">E-Mail</div>
              <div><a href="mailto:info@immobilien-koeln.example.com" class="text-indigo-600 hover:underline">info@immobilien-koeln.example.com</a></div>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2-1.343-2-3-2zm0-6c1.105 0 2 .895 2 2s-.895 2-2 2-2-.895-2-2 .895-2 2-2zm0 10c-4.411 0-8 3.589-8 8s3.589 8 8 8 8-3.589 8-8-3.589-8-8-8z"/></svg>
            </div>
            <div class="ml-3">
              <div class="font-medium">Öffnungszeiten</div>
              <div>Mo-Fr: 9:00 - 18:00 Uhr</div>
              <div>Sa: 10:00 - 14:00 Uhr</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .btn-primary {
    @apply bg-indigo-600 text-white;
  }
  
  /* Form validation styles */
  input:invalid, select:invalid, textarea:invalid {
    @apply border-red-500 focus:ring-red-500;
  }
  
  input:focus:invalid, select:focus:invalid, textarea:focus:invalid {
    @apply border-red-500 focus:ring-red-500;
  }
</style>
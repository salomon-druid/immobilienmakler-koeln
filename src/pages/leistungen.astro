---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceDetails from '../components/ServiceDetails.astro';
import ProcessSection from '../components/ProcessSection.astro';
import FAQSection from '../components/FAQSection.astro';
---
<Layout title="Leistungen">
  <Header activePage="leistungen" />
  <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
    <section class="mb-16">
      <h1 class="text-3xl font-bold text-gray-900 text-center mb-6">
        Unsere Leistungen
      </p>
      <p class="text-lg text-gray-600 text-center max-w-2xl mx-auto">
        Vollständiger Service rund um Ihre Immobilie - von der Bewertung über die Vermarktung bis zum erfolgreichen Abschluss.
      </p>
    </section>
    <ServiceDetails 
      items={[
        {
          title: "Immobilienbewertung",
          description: "Professionelle Marktpreisermittlung mit KI-Unterstützung für Wohn- und Gewerbeimmobilien in Köln und Umgebung."
        },
        {
          title: "Immobilienvermarktung",
          description: "Strategische Vermarktung mit professionellen Exposés, Zielgruppenansprache und Verhandlungsführung."
        },
        {
          title: "Finanzierungsberatung",
          description: "Unterstützung bei der Finanzierungsplanung und Vermittlung zu vertrauenswürdigen Finanzpartnern."
        },
        {
          title: "Rechtliche Begleitung",
          description: "Unterstützung bei allen rechtlichen Aspekten des Immobilienkaufs und -verkaufs."
        }
      ]} 
    />
    <ProcessSection />
    <FAQSection 
      items={[
        {
          question: "Wie lange dauert eine Immobilienbewertung?",
          answer: "Unsere Online-Bewertung liefert Ihnen innerhalb von 60 Sekunden eine erste Einschätzung. Für eine detaillierte Bewertung mit Vor-Ort-Termin benötigen wir in der Regel 2-3 Werktage."
        },
        {
          question: "Welche Unterlagen benötige ich für die Bewertung?",
          answer: "Für eine präzise Bewertung benötigen wir die Wohnfläche, das Baujahr, den Zustand und die Ausstattung Ihrer Immobilie. Je mehr Details Sie bereitstellen, desto genauer ist die Bewertung."
        },
        {
          question: "Wie hoch sind Ihre Provisionen?",
          answer: "Unsere Provisionen sind marktüblich und richten sich nach dem Verkaufspreis. Wir besprechen alle Kosten transparent im Vorfeld, damit es keine Überraschungen gibt."
        },
        {
          question: "Arbeiten Sie auch mit Investoren zusammen?",
          answer: "Ja, wir haben umfangreiche Erfahrung mit Kapitalanlegern und Investoren. Wir unterstützen Sie bei der Suche nach renditestarken Immobilien und deroptimierung Ihres Portfolios."
        }
      ]} 
    />
  </main>
  <Footer />
</Layout>

<style>
  /* Page-specific styles if needed */
</style>
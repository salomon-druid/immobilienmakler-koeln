---
const { title } = Astro.props;
// Get locale from URL parameter (for i18n routing) or default to 'de'
const locale = Astro.params.lang ?? 'de';
import SchemaOrg from '../components/SchemaOrg.astro';
---
<!DOCTYPE html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Immobilien Köln</title>
    <meta name="description" content="Professioneller Immobilienmakler in Köln mit KI-optimierten Dienstleistungen" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800&family=Lato:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/global.css" />
    <SchemaOrg />
  </head>
  <body class="min-h-screen flex flex-col">
    <header>
      <slot name="header" />
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer>
      <slot name="footer" />
    </footer>
  </body>
</html>
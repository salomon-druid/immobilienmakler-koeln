---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="de" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Immobilien Köln</title>
    <meta name="description" content="Professioneller Immobilienmakler in Köln mit KI-optimierten Dienstleistungen" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 font-serif antialiased">
    <div class="min-h-screen flex flex-col">
      <header>
        <slot name="header" />
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer>
        <slot name="footer" />
      </footer>
    </div>
  </body>
</html>

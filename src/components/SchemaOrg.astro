---
// Schema.org LocalBusiness JSON-LD
// This component generates structured data for search engines
const {
  name = "Immobilienmakler Köln",
  url = "https://immobilien-koeln.example.com",
  logo = "/logo.png",
  description = "Professioneller Immobilienmakler in Köln mit KI-optimierten Dienstleistungen",
  telephone = "+49 221 1234567",
  address = {
    streetAddress: "Musterstraße 123",
    addressLocality: "Köln",
    postalCode: "50667",
    addressCountry: "DE"
  },
  openingHours = [
    "Mo, Tu, We, Th, Fr 09:00-18:00",
    "Sa 10:00-14:00"
  ],
  priceRange = "€€€",
  geo = {
    latitude: 50.9375,
    longitude: 6.9603
  },
  sameAs = [
    "https://www.facebook.com/yourpage",
    "https://www.instagram.com/yourpage",
    "https://www.linkedin.com/company/yourpage"
  ]
} = Astro.props;
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "{name}",
  "url": "{url}",
  "logo": "{logo}",
  "description": "{description}",
  "telephone": "{telephone}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{address.streetAddress}",
    "addressLocality": "{address.addressLocality}",
    "postalCode": "{address.postalCode}",
    "addressCountry": "{address.addressCountry}"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday"
      ],
      "opens": "09:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "14:00"
    }
  ],
  "priceRange": "{priceRange}",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {geo.latitude},
    "longitude": {geo.longitude}
  },
  "sameAs": {JSON.stringify(sameAs)}
}
</script>
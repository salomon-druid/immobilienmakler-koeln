---
// AltbauGallery.astro
---
<section class="py-20 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">
      Schöne Altbauten in Köln
    </h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { src: '/images/koeln-altbau/K%C3%B6lner_Dom_vom_Rhein_aus.jpg', alt: 'Kölner Dom vom Rhein' },
        { src: '/images/koeln-altbau/Koln_Hohenzollernbruecke.jpg', alt: 'Hohenzollernbrücke Köln' },
        { src: '/images/koeln-altbau/K%C3%B6lner_Dom_vom_Rhein_aus.jpg', alt: 'Kölner Dom Blick' } // duplicate for demo, replace with actual
      ].map((image) => (
        <div class="bg-white rounded-lg overflow-hidden shadow hover:shadow-lg transition-shadow">
          <img src={image.src} alt={image.alt} class="w-full h-48 object-cover" />
          <div class="p-4">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{image.alt}</h3>
            <p class="text-sm text-gray-600">
              Historisches Gebäude in Köln, das den Charme der Stadt widerspiegelt.
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
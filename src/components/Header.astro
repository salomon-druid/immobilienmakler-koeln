---
const { title } = Astro.props;
---
<header class="bg-white shadow-sm border-b">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-between py-4">
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-xl font-bold text-gray-800">
          <img src="/logo.png" alt="Immobilien Köln Logo" class="h-10 w-auto" />
          <span class="ml-2">Immobilien Köln</span>
        </a>
      </div>
      <div class="hidden md:md:block">
        <nav class="ml-10 flex items-baseline space-x-4">
          <a href="/" class="{title === 'Startseite' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-500 hover:text-gray-700'} px-3 py-2 rounded-md text-sm font-medium">Startseite</a>
          <a href="/bewertung" class="{title === 'Bewertung' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-500 hover:text-gray-700'} px-3 py-2 rounded-md text-sm font-medium">Bewertung</a>
          <a href="/leistungen" class="{title === 'Leistungen' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-500 hover:text-gray-700'} px-3 py-2 rounded-md text-sm font-medium">Leistungen</a>
          <a href="/ueber-uns" class="{title === 'Über uns' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-500 hover:text-gray-700'} px-3 py-2 rounded-md text-sm font-medium">Über uns</a>
          <a href="/blog" class="{title === 'Blog' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-500 hover:text-gray-700'} px-3 py-2 rounded-md text-sm font-medium">Blog</a>
          <a href="/kontakt" class="{title === 'Kontakt' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-500 hover:text-gray-700'} px-3 py-2 rounded-md text-sm font-medium">Kontakt</a>
        </nav>
      </div>
      <div class="hidden md:block">
        <a href="/kontakt" class="px-3 py-2 rounded-md text-sm font-medium bg-indigo-600 text-white hover:bg-indigo-700">Kostenlose Bewertung</a>
      </div>
      <div class="-mr-2 flex items-center md:hidden">
        <!-- Mobile menu button -->
        <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 inactive:text-gray-400">
          <svg class="h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </div>
</header>

---
interface FAQItem {
  question: string;
  answer: string;
}
const { items } = Astro.props;
---
<section class="mb-16">
  <h2 class="text-2xl font-bold text-gray-900 mb-8">Häufig gestellte Fragen</p>
  <div class="space-y-4">
    {items.map((item, index) => (
      <div key={index} class="border-b pb-4 last:border-b-0 last:pb-0">
        <button class="w-full text-left flex justify-between items-center text-lg font-medium text-gray-900 hover:text-indigo-600 transition-colors"
                on:click={(e) => {
                  const answer = e.currentTarget.nextElementSibling;
                  answer.classList.toggle('hidden');
                  e.currentTarget.classList.toggle('rotated');
                }}>
          <span>{item.question}</span>
          <svg class="w-5 h-5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mt-2 text-gray-600 hidden">
          <p>{item.answer}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .rotated {
    @apply rotate-180;
  }
</style>
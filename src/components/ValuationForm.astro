---
// Props for pre-filling or showing results
export interface Props {
  /** If true, show loading state */
  loading?: boolean;
  /** If provided, show results instead of form */
  result?: {
    estimatedValue: number;
    confidence: number; // 0-100
    rangeLow: number;
    rangeHigh: number;
    comparableCount: number;
    marketTrend: string;
  };
}
const { loading = false, result } = Astro.props;
---
<form id="valuation-form" class="space-y-6" 
      on:submit={(e) => {
        e.preventDefault();
        // In a real app, this would send data to a backend
        // For now, we'll simulate with a client-side redirect or state change
        // This is a placeholder for the interactive functionality
        const form = e.target as HTMLFormElement;
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        // In a full implementation, we'd dispatch a custom event or use a store
        // For this static demo, we'll just show a success message
        alert('In a full implementation, this would submit to a backend and show results.\\n\\nThis is a static demo.');
      }}>
  
  {#if loading}
    <div class="text-center py-8">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
      <p class="mt-4 text-sm text-gray-600">Berechnung läuft...</p>
    </div>
  {:else if result}
    <div class="text-center">
      <div class="mb-6">
        <div class="inline-block w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mb-4">
          <svg class="h-8 w-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 1118 0z"/></svg>
        </div>
        <p class="text-2xl font-bold text-indigo-600">
          {result.estimatedValue.toLocaleString('de-DE')} €
        </p>
        <p class="text-sm text-gray-500">
          Schätzwert mit {result.confidence}% Sicherheit
        </p>
        <div class="mt-4 flex justify-center space-x-4 text-sm text-gray-600">
          <span>Spanne: {result.rangeLow.toLocaleString('de-DE')} € – {result.rangeHigh.toLocaleString('de-DE')} €</span>
          <span>|</span>
          <span>Basierend auf {result.comparableCount} Vergleichsobjekten</span>
        </div>
        <p class="mt-2 text-sm text-gray-600">
          Markttrend: {result.marketTrend}
        </p>
      </div>
      <div class="mt-6">
        <a href="/kontakt" 
           class="btn-primary px-6 py-3 text-sm font-medium rounded-lg hover:bg-indigo-700">
          Jetzt Beratung vereinbaren
        </a>
      </div>
    </div>
  {:else}
    <!-- Formular -->
    <div>
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        Immobilienangaben
      </h2>
      
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="strasse" class="block text-sm font-medium text-gray-700 mb-2">
            Straße und Hausnummer <span class="text-red-500">*</span>
          </label>
          <input type="text" id="strasse" name="strasse" required
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="Musterstraße 123" />
        </div>
        <div>
          <label for="hausnummer" class="block text-sm font-medium text-gray-700 mb-2">
            Hausnummer (falls getrennt)
          </label>
          <input type="text" id="hausnummer" name="hausnummer"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="123" />
        </div>
      </div>
      
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="plz" class="block text-sm font-medium text-gray-700 mb-2">
            Postleitzahl <span class="text-red-500">*</span>
          </label>
          <input type="text" id="plz" name="plz" required maxlength="5"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="50667" />
        </div>
        <div>
          <label for="ort" class="block text-sm font-medium text-gray-700 mb-2">
            Ort <span class="text-red-500">*</span>
          </label>
          <input type="text" id="ort" name="ort" required
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="Köln" />
        </div>
      </div>
      
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="immotyp" class="block text-sm font-medium text-gray-700 mb-2">
            Immobilientyp <span class="text-red-500">*</span>
          </label>
          <select id="immotyp" name="immotyp" required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            <option value="">-- Typ auswählen --</option>
            <option value="wohnung">Wohnung</option>
            <option value="haus">Ein-/Zweifamilienhaus</option>
            <option value="meetinghouse">Mehrfamilienhaus (3-8 Wohneinheiten)</option>
            <option value="grundstueck">Grundstück / Bauland</option>
            <option value="gewerbe">Gewerbeimmobilie</option>
          </select>
        </div>
        <div>
          <label for="baujahr" class="block text-sm font-medium text-gray-700 mb-2">
            Baujahr
          </label>
          <input type="number" id="baujahr" name="baujahr" min="1800" max={new Date().getFullYear()}
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="1995" />
        </div>
      </div>
      
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="zimmer" class="block text-sm font-medium text-gray-700 mb-2">
            Zimmerzahl
          </label>
          <input type="number" id="zimmer" name="zimmer" min="1"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="3" />
        </div>
        <div>
          <label for="schlafzimmer" class="block text-sm font-medium text-gray-700 mb-2">
            Schlafzimmer
          </label>
          <input type="number" id="schlafzimmer" name="schlafzimmer" min="0"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="2" />
        </div>
      </div>
      
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="flaeche" class="block text-sm font-medium text-gray-700 mb-2">
            Wohnfläche (m²) <span class="text-red-500">*</span>
          </label>
          <input type="number" id="flaeche" name="flaeche" required min="10"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="85" />
        </div>
        <div>
          <label for="grundstueck" class="block text-sm font-medium text-gray-700 mb-2">
            Grundstücksfläche (m²)
          </label>
          <input type="number" id="grundstueck" name="grundstueck" min="0"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="200" />
        </div>
      </div>
      
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="zustand" class="block text-sm font-medium text-gray-700 mb-2">
            Zustand
          </label>
          <select id="zustand" name="zustand"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            <option value="">-- Zustand auswählen --</option>
            <option value="sanierungsbedurftig">Sanierungsbedürftig</option>
            <option value=" renovierungsbedurftig">Renovierungsbedürftig</option>
            <option value="gepflegt">Gepflegt</option>
            <option value="neuwertig">Neuwertig / Saniert</option>
            <option value="luxus">Luxusausstattung</option>
          </select>
        </div>
        <div>
          <label for="ausstattung" class="block text-sm font-medium text-gray-700 mb-2">
            Besonderheiten (mehrfach auswählbar)
          </label>
          <div class="space-y-2">
            <label class="flex items-start">
              <div class="flex items-center h-4">
                <input id="balkon" type="checkbox" name="ausstattung" value="balkon" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>
              <div class="ml-3 text-sm">Balkon / Terrasse</div>
            </label>
            <label class="flex items-start">
              <div class="flex items-center h-4">
                <input id="garten" type="checkbox" name="ausstattung" value="garten" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>
              <div class="ml-3 text-sm">Garten</div>
            </label>
            <label class="flex items-start">
              <div class="flex items-center h-4">
                <input id="keller" type="checkbox" name="ausstattung" value="keller" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>
              <div class="ml-3 text-sm">Koller</div>
            </label>
            <label class="flex items-start">
              <div class="flex items-center h-4">
                <input id="aufzug" type="checkbox" name="ausstattung" value="aufzug" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>
              <div class="ml-3 text-sm">Aufzug</div>
            </label>
            <label class="flex items-start">
              <div class="flex items-center h-4">
                <input id="einbaukueche" type="checkbox" name="ausstattung" value="einbaukueche" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>
              <div class="ml-3 text-sm">Einbauküche</div>
            </label>
          </div>
        </div>
      </div>
      
      <div class="flex items-center pt-4">
        <div class="flex items-center h-4">
          <input id="datenschutz" type="checkbox" name="datenschutz" required
                 class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
        </div>
        <label for="datenschutz" class="ml-2 block text-sm text-gray-900">
          Ich habe die <a href="#" class="text-indigo-600 hover:underline">Datenschutzerklärung</a> gelesen und stimme ihr zu.
        </label>
      </div>
      
      <button type="submit"
              class="w-full btn-primary mt-6 px-6 py-4 text-lg font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus-ring-indigo-500 focus:ring-offset-2 disabled:opacity-50"
              :disabled={loading}>
        {#if loading}
          Berechnung läuft...
        {:else}
          Jetzt kostenlos bewerten lassen
        {/if}
      </button>
    </div>
  {/if}
</form>

<style>
  .btn-primary {
    @apply bg-indigo-600 text-white;
  }
  
  /* Form validation styles */
  input:invalid, select:invalid {
    @apply border-red-500 focus:ring-red-500;
  }
  
  input:focus:invalid, select:focus:invalid {
    @apply border-red-500 focus:ring-red-500;
  }
</style>

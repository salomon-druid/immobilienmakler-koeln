<section class="py-20 bg-indigo-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-gray-900">
        Kostenlose Immobilienbewertung in nur 60 Sekunden
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Erhalten Sie eine präzise Marktpreis-Einschätzung basierend auf aktuellen Daten und KI-Analyse.
      </p>
    </div>
    <div class="bg-white rounded-xl shadow-xl p-8">
      <form action="#" method="POST" class="space-y-6">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="strasse" class="block text-sm font-medium text-gray-700 mb-2">
              Straße und Hausnummer
            </label>
            <input type="text" id="strasse" name="strasse" required
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                   placeholder="Musterstraße 123" />
          </div>
          <div>
            <label for="plz" class="block text-sm font-medium text-gray-700 mb-2">
              Postleitzahl
            </label>
            <input type="text" id="plz" name="plz" required maxlength="5"
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                   placeholder="50667" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ort" class="block text-sm font-medium text-gray-700 mb-2">
              Ort
            </label>
            <input type="text" id="ort" name="ort" required
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                   placeholder="Köln" />
          </div>
          <div>
            <label for="immotyp" class="block text-sm font-medium text-gray-700 mb-2">
              Immobilientyp
            </label>
            <select id="immotyp" name="immotyp" required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
              <option value="">-- Typ auswählen --</option>
              <option value="wohnung">Wohnung</option>
              <option value="haus">Haus</option>
              <option value="meetinghouse">Mehrfamilienhaus</option>
              <option value="grundstueck">Grundstück</option>
            </select>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="zimmer" class="block text-sm font-medium text-gray-700 mb-2">
              Zimmerzahl
            </label>
            <input type="number" id="zimmer" name="zimmer" min="1"
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                   placeholder="3" />
          </div>
          <div>
            <label for="flaeche" class="block text-sm font-medium text-gray-700 mb-2">
              Wohnfläche (m²)
            </label>
            <input type="number" id="flaeche" name="flaeche" min="10"
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                   placeholder="85" />
          </div>
        </div>

        <button type="submit"
                class="w-full bg-indigo-600 text-white px-6 py-3 text-lg font-medium rounded-lg hover:bg-indigo-700 transition-colors focus:outline-none focus:ring-2 focus-ring-indigo-500 focus:ring-offset-2">
          Jetzt kostenlos bewerten lassen
        </button>
      </form>
      <p class="mt-4 text-sm text-gray-500">
        Ihre Daten werden vertraulich behandelt und nicht an Dritte weitergegeben.
      </p>
    </div>
  </div>
</section>
